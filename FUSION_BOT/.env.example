# FUSION Bot konfiguratsiya
# Shu faylni .env ga ko'chirib, qiymatlarni to'ldiring.

# Telegram Bot Token (@BotFather dan olinadi)
BOT_TOKEN=1234567890:AABBCCddeeffgghhii

# Admin Telegram ID (bir nechta bo'lsa vergul bilan)
ADMIN_IDS=123456789

# MetaTrader 5 terminal yo'li (VPS da)
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Savdo dvigateli: PYTHON yoki EA. Ikkalasini bir vaqtda ishlatmang.
# PYTHON — Telegram botning ichki trader.py dvigateli (tavsiya etiladi).
# EA — MT5 chartiga o'rnatilgan FUSION.mq5, fayl bridge orqali boshqariladi.
TRADING_ENGINE=PYTHON

# Database yo'li
DB_PATH=fusion_bot.db

# Shifrlash kaliti (Fernet) — yaratish uchun:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here
